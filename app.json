{
  "expo": {
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f902d8fa-d63a-49f7-8b32-d87e4d5bc653",
      "channel": "production"
    },
    "name": "Best Eats",
    "slug": "best-eats",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#5A2328"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.team7llc.besteats",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Best Eats needs your location to show nearby restaurants."
      }
    },
    "android": {
      "package": "com.team7llc.besteats",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Best Eats to use your location to find nearby restaurants."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f902d8fa-d63a-49f7-8b32-d87e4d5bc653"
      }
    }
  }
}
